    "react-native-battery-optimization-check": "^1.0.8",
    "react-native-paper": "^5.15.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-vector-icons": "^10.3.0",
    "upigateway": "^1.0.4"
  },
  "devDependencies": {
